# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Copy from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose in browser code or commit to git
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (P1 sets up, shares with team) ───────────────────────────────
# Copy from: Google Cloud Console → Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI / Resume extraction (P1 owns) ─────────────────────────────────────────
OPENAI_API_KEY=

# ── Phone encryption (P1 owns) ───────────────────────────────────────────────
PHONE_ENCRYPTION_KEY=

# ── Push notifications (P4 owns) ─────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Error tracking (P1 owns) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Admin allowlist ───────────────────────────────────────────────────────────
# Comma-separated emails that are granted admin role via Supabase Google auth
ADMIN_EMAILS=founder@example.com
